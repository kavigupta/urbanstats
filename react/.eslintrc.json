{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "settings": {
    "import/extensions": [
      ".js",
      ".jsx",
      ".mjs",
      ".cjs",
      ".ts",
      ".tsx",
      ".mts",
      ".cts"
    ],
    "import/resolver": {
      "typescript": true,
      "node": true
    },
    "import/parsers": {
      "@typescript-eslint/parser": [
        ".ts",
        ".tsx",
        ".mts",
        ".cts"
      ]
    }
  },
  "ignorePatterns": [
    "**/*.{js,mjs}",
    "src/utils/protos.d.ts",
    "src/utils/urbanstats-persistent-data.d.ts",
    "src/utils/google-drive.d.ts",
    "src/data/**"
  ]
}
